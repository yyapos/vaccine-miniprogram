/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 通用按钮样式 */
.btn {
  border-radius: 6rpx;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
  border: none;
}

.btn-primary {
  background-color: #4A90E2;
  color: white;
}

.btn-secondary {
  background-color: #ffffff;
  color: #4A90E2;
  border: 1rpx solid #4A90E2;
}

/* 通用卡片样式 */
.card {
  background-color: white;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

/* 通用标题样式 */
.section-title {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
  color: #333;
}

/* 通用表单样式 */
.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  margin-bottom: 12rpx;
  color: #333;
}

.form-input {
  background-color: white;
  border: 1rpx solid #ddd;
  border-radius: 6rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

/* 通用空状态样式 */
.empty-state {
  text-align: center;
  padding: 80rpx 20rpx;
  color: #999;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  margin-bottom: 30rpx;
}