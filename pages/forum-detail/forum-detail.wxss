.container {
  min-height: 100vh;
  background: #FAFBFC;
  padding-bottom: 140rpx;
}

/* 帖子详情 */
.post-detail {
  background: white;
  margin: 20rpx;
  margin-bottom: 16rpx;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.author-info {
  display: flex;
  align-items: center;
}

.author-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  margin-right: 14rpx;
  border: 2rpx solid #F0F0F0;
}

.author-details {
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 4rpx;
}

.post-time {
  font-size: 23rpx;
  color: #95A5A6;
}

.post-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C3E50;
  line-height: 1.6;
  margin-bottom: 24rpx;
  letter-spacing: 0.3rpx;
}

.post-content {
  font-size: 29rpx;
  color: #5A6C7D;
  line-height: 1.9;
  margin-bottom: 24rpx;
  letter-spacing: 0.2rpx;
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.post-image {
  width: 220rpx;
  height: 220rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.tag-item {
  font-size: 24rpx;
  color: #FF9A9E;
  background: #FFF5F5;
  padding: 8rpx 18rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.post-footer {
  border-top: 1rpx solid #F0F1F3;
  padding-top: 20rpx;
}

.post-stats {
  display: flex;
  gap: 48rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 16rpx;
  border-radius: 16rpx;
  transition: background 0.2s ease;
}

.stat-item:active {
  background: #F8F9FB;
}

.stat-icon {
  font-size: 32rpx;
  filter: drop-shadow(0 1rpx 2rpx rgba(0, 0, 0, 0.1));
}

.stat-text {
  font-size: 26rpx;
  color: #7A8A9A;
  font-weight: 500;
}

/* 评论区域 */
.comments-section {
  background: white;
  margin: 0 20rpx 20rpx;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C3E50;
  letter-spacing: 0.5rpx;
}

.empty-comments {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 16rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

.empty-text {
  font-size: 26rpx;
  color: #95A5A6;
  letter-spacing: 0.5rpx;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.comment-item {
  padding-bottom: 28rpx;
  border-bottom: 1rpx solid #F0F1F3;
}

.comment-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.comment-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.comment-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  margin-right: 14rpx;
  border: 2rpx solid #F0F0F0;
}

.comment-info {
  flex: 1;
}

.comment-author {
  font-size: 27rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 2rpx;
}

.comment-time {
  font-size: 23rpx;
  color: #95A5A6;
}

.comment-delete {
  font-size: 24rpx;
  color: #95A5A6;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  transition: all 0.2s ease;
}

.comment-delete:active {
  background: #FFF5F5;
  color: #FF9A9E;
}

.comment-content {
  font-size: 28rpx;
  color: #5A6C7D;
  line-height: 1.7;
  margin-bottom: 16rpx;
  letter-spacing: 0.2rpx;
}

.comment-footer {
  display: flex;
  gap: 48rpx;
}

.comment-likes {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 12rpx;
  border-radius: 12rpx;
}

.like-icon {
  font-size: 24rpx;
}

.like-count {
  font-size: 23rpx;
  color: #95A5A6;
  font-weight: 500;
}

/* 评论输入框 */
.comment-input-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.comment-input-wrapper {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.comment-input {
  flex: 1;
  background: #F8F9FB;
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #2C3E50;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.comment-input:focus {
  background: white;
  border-color: #FF9A9E;
  box-shadow: 0 0 0 4rpx rgba(255, 154, 158, 0.1);
}

.comment-btn {
  background: linear-gradient(135deg, #FF9A9E 0%, #FECFEF 100%);
  color: white;
  border: none;
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 158, 0.3);
  transition: all 0.3s ease;
}

.comment-btn:active {
  transform: scale(0.96);
}

.comment-btn[disabled] {
  background: #E0E0E0;
  box-shadow: none;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-icon {
  font-size: 100rpx;
  margin-bottom: 16rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

.loading-text {
  font-size: 27rpx;
  color: #95A5A6;
  letter-spacing: 0.5rpx;
}