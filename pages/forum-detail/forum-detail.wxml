<view class="container" wx:if="{{ post }}">
  <!-- 帖子内容 -->
  <view class="post-detail">
    <view class="post-header">
      <view class="author-info">
        <image class="author-avatar" src="{{ post.userAvatar || '/assets/default-avatar.png' }}" mode="aspectFill"></image>
        <view class="author-details">
          <view class="author-name">{{ post.nickname }}</view>
          <view class="post-time">{{ post.createTime }}</view>
        </view>
      </view>
    </view>
    
    <view class="post-title">{{ post.title }}</view>
    <view class="post-content">{{ post.content }}</view>
    
    <view class="post-images" wx:if="{{ post.images }}">
      <image 
        class="post-image" 
        wx:for="{{ post.images }}" 
        wx:for-item="img" 
        wx:key="*this"
        src="{{ img }}" 
        mode="aspectFill"
        bindtap="previewImage"
        data-url="{{ img }}">
      </image>
    </view>
    
    <view class="post-tags" wx:if="{{ post.tags }}">
      <view class="tag-item" wx:for="{{ post.tags }}" wx:key="*this">#{{ item }}</view>
    </view>
    
    <view class="post-footer">
      <view class="post-stats">
        <view class="stat-item" bindtap="toggleLike">
          <text class="stat-icon">{{ isLiked ? '❤️' : '👍' }}</text>
          <text class="stat-text">{{ post.likeCount || 0 }}</text>
        </view>
        <view class="stat-item">
          <text class="stat-icon">💬</text>
          <text class="stat-text">{{ post.commentCount || 0 }}</text>
        </view>
        <view class="stat-item">
          <text class="stat-icon">👁️</text>
          <text class="stat-text">{{ post.viewCount || 0 }}</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 评论区域 -->
  <view class="comments-section">
    <view class="section-header">
      <view class="section-title">评论 ({{ comments.length }})</view>
    </view>
    
    <view wx:if="{{ comments.length === 0 }}" class="empty-comments">
      <view class="empty-icon">💬</view>
      <view class="empty-text">暂无评论，快来抢沙发吧~</view>
    </view>
    
    <view class="comment-list">
      <view class="comment-item" wx:for="{{ comments }}" wx:key="id">
        <view class="comment-header">
          <image class="comment-avatar" src="{{ item.userAvatar || '/assets/default-avatar.png' }}" mode="aspectFill"></image>
          <view class="comment-info">
            <view class="comment-author">{{ item.nickname }}</view>
            <view class="comment-time">{{ item.createTime }}</view>
          </view>
          <view class="comment-delete" wx:if="{{ item.canDelete }}" bindtap="deleteComment" data-id="{{ item.id }}">删除</view>
        </view>
        <view class="comment-content">{{ item.content }}</view>
        <view class="comment-footer">
          <view class="comment-likes">
            <text class="like-icon">👍</text>
            <text class="like-count">{{ item.likeCount || 0 }}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 评论输入框 -->
  <view class="comment-input-section">
    <view class="comment-input-wrapper">
      <input
        class="comment-input"
        placeholder="写下你的评论..."
        value="{{ commentInput }}"
        bindinput="onCommentInput"
        confirm-type="send"
        bindconfirm="submitComment"
      />
      <button class="comment-btn" bindtap="submitComment" disabled="{{ commentInput.length === 0 }}">发送</button>
    </view>
  </view>
</view>

<!-- 加载状态 -->
<view wx:elif="{{ loading }}" class="loading-state">
  <view class="loading-icon">⏳</view>
  <view class="loading-text">加载中...</view>
</view>