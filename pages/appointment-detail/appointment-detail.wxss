.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 20rpx;
}

.loading-state {
  text-align: center;
  padding: 200rpx 0;
}

.loading-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.status-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 60rpx;
  text-align: center;
  color: white;
  margin-bottom: 30rpx;
}

.status-0 {
  background: linear-gradient(135deg, #F093FB 0%, #F5576C 100%);
}

.status-1 {
  background: linear-gradient(135deg, #4FACFE 0%, #00F2FE 100%);
}

.status-2 {
  background: linear-gradient(135deg, #FA709A 0%, #FEE140 100%);
}

.status-3 {
  background: linear-gradient(135deg, #43E97B 0%, #38F9D7 100%);
}

.status-4 {
  background: linear-gradient(135deg, #A18CD1 0%, #FBC2EB 100%);
}

.status-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 40rpx;
  font-weight: bold;
}

.card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  flex: 1;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  flex: 2;
}

.view-more {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #4A90E2;
  text-align: right;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn {
  flex: 1;
  padding: 30rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.btn-primary {
  background: #4A90E2;
  color: white;
}

.btn-danger {
  background: #F56C6C;
  color: white;
}