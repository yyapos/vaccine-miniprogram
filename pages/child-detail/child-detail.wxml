<view class="container"> <view wx:if="{{ loading}}" class="loading-state"> <text>加载中...</text> </view> <view wx:else class="detail-content"> <view class="header"> <view class="child-avatar"> {{ child.name ? child.name.charAt(0) : '?' }} </view> <view class="child-info"> <view class="child-name">{{ child.name }}</view> <view class="child-meta"> <text>{{ child.gender === 1 ? '男' : '女' }}</text> <text class="separator">|</text> <text>{{ child.birthDate }}</text> </view> </view> </view> <view class="info-section"> <view class="section-title">基本信息</view> <view class="info-item"> <view class="label">姓名</view> <view class="value">{{ child.name }}</view> </view> <view class="info-item"> <view class="label">性别</view> <view class="value">{{ child.gender === 1 ? '男' : '女' }}</view> </view> <view class="info-item"> <view class="label">出生日期</view> <view class="value">{{ child.birthDate }}</view> </view> <view class="info-item"> <view class="label">身份证号</view> <view class="value">{{ child.idCard || '未填写' }}</view> </view> <view class="info-item"> <view class="label">家庭住址</view> <view class="value">{{ child.address || '未填写' }}</view> </view> <view wx:if="{{ child.isKeyChild === 1}}" class="info-item key-child"> <view class="label">重点儿童</view> <view class="value">{{ child.keyReason }}</view> </view> </view> <view class="action-bar"> <button class="action-btn edit-btn" bindtap="onEdit">编辑</button> <button class="action-btn delete-btn" bindtap="onDelete">删除</button> </view> </view> </view>
