.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.detail-card {
  background-color: white;
  border-radius: 12rpx;
  overflow: hidden;
}

.vaccine-header {
  padding: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.vaccine-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.vaccine-code {
  font-size: 24rpx;
  opacity: 0.9;
}

.stock-section {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stock-label {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.stock-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.stock-normal {
  background-color: #f6ffed;
  color: #52c41a;
}

.stock-low {
  background-color: #fff7e6;
  color: #fa8c16;
}

.stock-empty {
  background-color: #fff1f0;
  color: #f5222d;
}

.stock-count {
  font-size: 24rpx;
  color: #999;
}

.info-section {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.desc-section {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.info-item {
  display: flex;
  margin-bottom: 24rpx;
  font-size: 28rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  color: #999;
  width: 180rpx;
  flex-shrink: 0;
}

.info-value {
  color: #333;
  flex: 1;
}

.desc-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.action-buttons {
  padding: 30rpx;
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
}

.btn-back {
  background-color: white;
  color: #4A90E2;
  border: 1rpx solid #4A90E2;
}

.btn-book {
  background-color: #4A90E2;
  color: white;
}

.btn-book[disabled] {
  background-color: #d9d9d9;
  color: #999;
}