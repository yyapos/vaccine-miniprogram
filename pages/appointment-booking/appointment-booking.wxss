.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.form-card {
  background-color: white;
  border-radius: 8rpx;
  padding: 32rpx 24rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 32rpx;
  text-align: center;
}

.info-section {
  margin-bottom: 32rpx;
  padding: 24rpx;
  background-color: #f9f9f9;
  border-radius: 6rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  margin-bottom: 14rpx;
  font-size: 28rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  color: #999;
  width: 180rpx;
  flex-shrink: 0;
}

.info-value {
  color: #333;
  flex: 1;
}

.form-section {
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.required {
  color: #ff4d4f;
  margin-left: 4rpx;
}

.picker-input {
  width: 100%;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 6rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  line-height: 80rpx;
  color: #333;
}

.form-actions {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 6rpx;
  font-size: 28rpx;
  border: none;
}

.btn-primary {
  background-color: #4A90E2;
  color: white;
}

.btn-secondary {
  background-color: white;
  color: #4A90E2;
  border: 1rpx solid #4A90E2;
}