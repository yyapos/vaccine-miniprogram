.container {
  padding: 20rpx;
}

.user-header {
  background-color: #4A90E2;
  padding: 32rpx;
  border-radius: 8rpx;
  color: white;
  margin-bottom: 24rpx;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 20rpx;
}

.user-details {
  flex: 1;
}

.nickname {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.phone {
  font-size: 24rpx;
  opacity: 0.9;
}

.stats {
  display: flex;
  gap: 48rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.9;
}

.function-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.function-item {
  background: white;
  padding: 24rpx;
  border-radius: 8rpx;
  text-align: center;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

.function-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
  position: relative;
}

.badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  background: #ff4d4f;
  color: white;
  font-size: 20rpx;
  min-width: 28rpx;
  height: 28rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
  font-weight: 500;
}

.function-name {
  font-size: 28rpx;
  font-weight: 400;
  color: #333;
  margin-bottom: 6rpx;
}

.function-desc {
  font-size: 24rpx;
  color: #999;
}

.recent-appointments {
  background: white;
  padding: 24rpx;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #4A90E2;
}

.appointment-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.appointment-item:last-child {
  border-bottom: none;
}

.appointment-info {
  flex: 1;
}

.appointment-child {
  font-size: 28rpx;
  font-weight: 400;
  color: #333;
  margin-bottom: 6rpx;
}

.appointment-vaccine {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.appointment-date {
  font-size: 24rpx;
  color: #999;
}

.appointment-status {
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.status-0 {
  background: #FDF6EC;
  color: #E6A23C;
}

.status-1 {
  background: #F0F9FF;
  color: #67C23A;
}

.status-2 {
  background: #FEF0F0;
  color: #F56C6C;
}

.status-3 {
  background: #F0F9FF;
  color: #4A90E2;
}

.status-4 {
  background: #F5F5F5;
  color: #999;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.btn {
  padding: 20rpx 40rpx;
  border-radius: 6rpx;
  font-size: 28rpx;
  border: none;
}

.btn-primary {
  background: #4A90E2;
  color: white;
}

.quick-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  background: white;
  padding: 24rpx;
  border-radius: 8rpx;
  text-align: center;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

.action-icon {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.action-name {
  font-size: 26rpx;
  color: #333;
}