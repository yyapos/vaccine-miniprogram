<view class="container">
  <!-- 头部用户信息 -->
  <view class="user-header">
    <view class="user-info">
      <image 
        class="avatar" 
        src="{{ userInfo.avatar || 'data:image/svg+xml;base64,' }}" 
        mode="aspectFill">
      </image>
      <view class="user-details">
        <view class="nickname">{{ userInfo.nickname || '微信用户' }}</view>
        <view class="phone">{{ userInfo.phone || '未绑定手机号' }}</view>
      </view>
    </view>
    <view class="stats">
      <view class="stat-item">
        <view class="stat-value">{{ children.length }}</view>
        <view class="stat-label">儿童</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{ appointmentCount }}</view>
        <view class="stat-label">预约</view>
      </view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="function-grid">
    <view class="function-item" bindtap="navigateTo" data-url="/pages/children/children">
      <view class="function-icon child-icon">👶</view>
      <view class="function-name">儿童管理</view>
      <view class="function-desc">管理孩子的信息</view>
    </view>
    
    <view class="function-item" bindtap="navigateTo" data-url="/pages/vaccine-list/vaccine-list">
      <view class="function-icon vaccine-icon">💉</view>
      <view class="function-name">疫苗预约</view>
      <view class="function-desc">为孩子预约疫苗接种</view>
    </view>
    
    <view class="function-item" bindtap="navigateTo" data-url="/pages/records/records">
      <view class="function-icon record-icon">📋</view>
      <view class="function-name">接种记录</view>
      <view class="function-desc">查看历史接种记录</view>
    </view>
    
    <view class="function-item" bindtap="showNotice">
      <view class="function-icon notice-icon">
        🔔
        <view class="badge" wx:if="{{ unreadReminderCount > 0 }}">
          {{ unreadReminderCount > 99 ? '99+' : unreadReminderCount }}
        </view>
      </view>
      <view class="function-name">接种提醒</view>
      <view class="function-desc">查看接种提醒通知</view>
    </view>
  </view>

  <!-- 最近预约 -->
  <view class="recent-appointments">
    <view class="section-header">
      <view class="section-title">最近预约</view>
      <view class="section-more" bindtap="navigateTo" data-url="/pages/records/records">查看全部</view>
    </view>
    
    <view class="appointment-list">
      <view wx:if="{{ recentAppointments.length === 0 }}" class="empty-state">
        <view class="empty-icon">📅</view>
        <view class="empty-text">暂无预约记录</view>
        <button class="btn btn-primary" bindtap="navigateTo" data-url="/pages/vaccine-list/vaccine-list">立即预约</button>
      </view>
      
      <view class="appointment-item" wx:for="{{ displayAppointments }}" wx:key="id" bindtap="viewAppointment" data-id="{{ item.id }}">
        <view class="appointment-info">
          <view class="appointment-child">{{ item.childName }}</view>
          <view class="appointment-vaccine">{{ item.vaccineName }}</view>
          <view class="appointment-date">{{ item.appointmentDate }}</view>
        </view>
        <view class="appointment-status status-{{ item.status }}">{{ item.statusText }}</view>
      </view>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="quick-actions">
    <view class="action-btn" bindtap="navigateTo" data-url="/pages/child-add/child-add">
      <view class="action-icon">➕</view>
      <view class="action-name">添加儿童</view>
    </view>
    <view class="action-btn" bindtap="navigateTo" data-url="/pages/vaccine-list/vaccine-list">
      <view class="action-icon">📝</view>
      <view class="action-name">立即预约</view>
    </view>
  </view>
</view>