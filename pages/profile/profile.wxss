.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.user-card {
  background-color: #4A90E2;
  border-radius: 8rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 2rpx solid white;
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 30rpx;
  font-weight: 400;
  color: white;
  margin-bottom: 8rpx;
}

.phone {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.function-list {
  background-color: white;
  border-radius: 8rpx;
  overflow: hidden;
}

.function-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.function-item:last-child {
  border-bottom: none;
}

.function-icon {
  font-size: 34rpx;
  margin-right: 18rpx;
}

.function-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.logout-text {
  color: #ff4d4f;
}

.function-arrow {
  font-size: 34rpx;
  color: #999;
}

.version-info {
  text-align: center;
  margin-top: 32rpx;
  font-size: 24rpx;
  color: #999;
}