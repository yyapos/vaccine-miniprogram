<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <image 
      class="avatar" 
      src="{{ userInfo.avatar || 'data:image/svg+xml;base64,' }}" 
      mode="aspectFill">
    </image>
    <view class="user-info">
      <view class="nickname">{{ userInfo.nickname || '微信用户' }}</view>
      <view class="phone">{{ userInfo.phone || '未绑定手机号' }}</view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="function-list">
    <view class="function-item" bindtap="handleAbout">
      <view class="function-icon">ℹ️</view>
      <view class="function-text">关于我们</view>
      <view class="function-arrow">›</view>
    </view>
    
    <view class="function-item" bindtap="handleContact">
      <view class="function-icon">📞</view>
      <view class="function-text">联系客服</view>
      <view class="function-arrow">›</view>
    </view>
    
    <view class="function-item" bindtap="handleCheckUpdate">
      <view class="function-icon">🔄</view>
      <view class="function-text">检查更新</view>
      <view class="function-arrow">›</view>
    </view>
    
    <view class="function-item" bindtap="handleLogout">
      <view class="function-icon">🚪</view>
      <view class="function-text logout-text">退出登录</view>
      <view class="function-arrow">›</view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>疫苗预约小程序 v1.0.0</text>
  </view>
</view>