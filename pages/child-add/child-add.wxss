.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.form-card {
  background-color: white;
  border-radius: 8rpx;
  padding: 32rpx 24rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 400;
  color: #333;
  margin-bottom: 32rpx;
  text-align: center;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.required {
  color: #ff4d4f;
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 6rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-input {
  width: 100%;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 6rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  line-height: 80rpx;
  color: #333;
}

.form-desc {
  font-size: 24rpx;
  color: #999;
  margin-left: 20rpx;
}

.form-actions {
  display: flex;
  justify-content: space-between;
  margin-top: 40rpx;
  gap: 16rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 6rpx;
  font-size: 28rpx;
  border: none;
}

.btn-primary {
  background-color: #4A90E2;
  color: white;
}

.btn-secondary {
  background-color: white;
  color: #4A90E2;
  border: 1rpx solid #4A90E2;
}