.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.child-select {
  background-color: white;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.select-label {
  font-size: 28rpx;
  color: #333;
  margin-right: 16rpx;
}

.picker-view {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #4A90E2;
}

.arrow {
  font-size: 24rpx;
  color: #999;
}

.vaccine-list {
  padding: 10rpx 0;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  background-color: white;
  border-radius: 8rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.vaccine-item {
  background-color: white;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.vaccine-header {
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.vaccine-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.vaccine-code {
  font-size: 24rpx;
  color: #999;
  padding: 6rpx 12rpx;
  background-color: #f5f5f5;
  border-radius: 4rpx;
}

.vaccine-info {
  padding: 24rpx;
}

.info-row {
  display: flex;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  color: #999;
  width: 180rpx;
  flex-shrink: 0;
}

.info-value {
  color: #333;
  flex: 1;
}

.stock {
  font-weight: 400;
}

.stock-normal {
  color: #52c41a;
}

.stock-low {
  color: #fa8c16;
}

.stock-empty {
  color: #f5222d;
}

.stock-count {
  color: #999;
  font-size: 24rpx;
  margin-left: 10rpx;
}

.vaccine-actions {
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 6rpx;
  font-size: 28rpx;
  border: none;
}

.btn-detail {
  background-color: white;
  color: #4A90E2;
  border: 1rpx solid #4A90E2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-book {
  background-color: #4A90E2;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-book[disabled] {
  background-color: #d9d9d9;
  color: #999;
}