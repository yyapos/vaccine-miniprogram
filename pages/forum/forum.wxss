.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.search-bar {
  background-color: white;
  padding: 20rpx;
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.search-input {
  flex: 1;
  background-color: #f5f5f5;
  border-radius: 6rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.search-btn {
  background-color: #4A90E2;
  color: white;
  border: none;
  border-radius: 6rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

.post-list {
  padding: 20rpx;
}

.post-item {
  background-color: white;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.author-info {
  display: flex;
  align-items: center;
}

.author-avatar {
  width: 76rpx;
  height: 76rpx;
  background-color: #4A90E2;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  color: white;
  font-size: 32rpx;
  font-weight: 400;
  margin-right: 18rpx;
}

.author-details {
}

.author-name {
  font-size: 28rpx;
  font-weight: 400;
  color: #333;
}

.post-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.post-stats {
  display: flex;
  gap: 16rpx;
  font-size: 24rpx;
  color: #999;
}

.post-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.post-content {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.post-footer {
}

.post-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.tag {
  font-size: 24rpx;
  color: #4A90E2;
  background-color: #e3f2fd;
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
}

.fab {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  width: 110rpx;
  height: 110rpx;
  background-color: #4A90E2;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(74, 144, 226, 0.3);
}

.fab-icon {
  font-size: 56rpx;
  color: white;
}