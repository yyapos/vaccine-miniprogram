<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索帖子" bindinput="onSearchInput" value="{{ keyword}}" />
    <button class="search-btn" bindtap="onSearch">搜索</button>
  </view> <!-- 帖子列表 -->
  <view class="post-list">
    <view wx:if="{{ posts.length === 0 && !loading}}" class="empty-state">
      <view class="empty-icon">💬</view>
      <view class="empty-text">暂无帖子</view> <button class="btn btn-primary" bindtap="createPost">发布第一个帖子</button>
    </view>
    <view class="post-item" wx:for="{{ posts}}" wx:key="id" bindtap="viewPost" data-id="{{ item.id}}">
      <view class="post-header">
        <view class="author-info">
          <view class="author-avatar">{{ item.authorName ? item.authorName.charAt(0) : '?' }}</view>
          <view class="author-details">
            <view class="author-name">{{ item.authorName }}</view>
            <view class="post-time">{{ item.createTime }}</view>
          </view>
        </view>
        <view class="post-stats"> <text>👍 {{ item.likeCount }}</text> <text>💬 {{ item.commentCount }}</text> </view>
      </view>
      <view class="post-title">{{ item.title }}</view>
      <view class="post-content">{{ item.content }}</view>
      <view class="post-footer">
        <view class="post-tags"> <text class="tag" wx:for="{{ item.tags}}" wx:key="index">#{{ item }}</text> </view>
      </view>
    </view>
    <view wx:if="{{ loading}}" class="loading"> <text>加载中...</text> </view>
    <view wx:if="{{ !hasMore && posts.length > 0}}" class="no-more"> <text>没有更多了</text> </view>
  </view> <!-- 悬浮发布按钮 -->
  <view class="fab" bindtap="createPost"> <text class="fab-icon">+</text> </view>
</view>