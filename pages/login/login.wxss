.login-container {
  min-height: 100vh;
  background-color: #4A90E2;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.login-content {
  width: 100%;
  max-width: 640rpx;
  background: white;
  border-radius: 12rpx;
  padding: 60rpx 48rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-bottom: 48rpx;
}

.logo-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
  letter-spacing: 2rpx;
}

.app-desc {
  font-size: 26rpx;
  color: #999;
  letter-spacing: 1rpx;
}

/* 信息输入区域 */
.info-section {
  margin-bottom: 48rpx;
}

.info-item {
  margin-bottom: 28rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 14rpx;
  font-weight: 400;
}

/* 头像选择 */
.avatar-btn {
  width: 100%;
  height: auto;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar-btn::after {
  border: none;
}

.avatar-image {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 2rpx solid #4A90E2;
  background: #f5f5f5;
}

.avatar-tip {
  font-size: 26rpx;
  color: #999;
}

/* 昵称输入 */
.nickname-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border: 1rpx solid transparent;
  border-radius: 8rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #333;
  transition: all 0.3s;
}

.nickname-input:focus {
  background: white;
  border-color: #4A90E2;
}

/* 性别选择 */
.radio-group {
  display: flex;
  gap: 24rpx;
}

.radio-label {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.radio-label.active {
  background: #e8f4fd;
}

.radio-label text {
  font-size: 28rpx;
  color: #666;
  margin-left: 10rpx;
}

.radio-label.active text {
  color: #4A90E2;
  font-weight: 400;
}

/* 城市选择 */
.picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 28rpx;
  transition: all 0.3s;
}

.picker-box.selected {
  background: white;
  border: 1rpx solid #4A90E2;
}

.picker-box text:first-child {
  font-size: 28rpx;
  color: #999;
}

.picker-box.selected text:first-child {
  color: #333;
}

.picker-arrow {
  font-size: 36rpx;
  color: #4A90E2;
  font-weight: 300;
}

/* 操作区域 */
.action-section {
  margin-bottom: 32rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  background-color: #4A90E2;
  color: white;
  border: none;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 400;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(74, 144, 226, 0.3);
  transition: all 0.3s;
}

.login-btn::after {
  border: none;
}

.login-btn[disabled] {
  background-color: #ccc;
  box-shadow: none;
  opacity: 0.6;
}

.btn-icon {
  font-size: 32rpx;
}

/* 提示区域 */
.tips-section {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  line-height: 1.8;
}

.tips-section .link {
  color: #4A90E2;
}