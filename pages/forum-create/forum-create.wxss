.container { min-height: 100vh; background-color: #f5f5f5; padding-bottom: 120rpx; } .form { background-color: white; padding: 30rpx; margin-bottom: 20rpx; } .form-item { margin-bottom: 40rpx; } .form-item:last-child { margin-bottom: 0; } .label { font-size: 28rpx; font-weight: bold; color: #333; margin-bottom: 20rpx; } .input, .textarea { background-color: #f5f5f5; border-radius: 8rpx; padding: 20rpx; font-size: 28rpx; width: 100%; box-sizing: border-box; } .textarea { min-height: 200rpx; } .char-count { text-align: right; font-size: 24rpx; color: #999; margin-top: 10rpx; } .tag-input-wrapper { display: flex; gap: 20rpx; } .tag-input { flex: 1; background-color: #f5f5f5; border-radius: 8rpx; padding: 20rpx; font-size: 28rpx; } .add-btn { background-color: #4A90E2; color: white; border: none; border-radius: 8rpx; padding: 20rpx 30rpx; font-size: 28rpx; } .tags-list { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 20rpx; } .tag-item { background-color: #e3f2fd; color: #4A90E2; padding: 10rpx 20rpx; border-radius: 20rpx; font-size: 24rpx; display: flex; align-items: center; gap: 10rpx; } .remove-tag { font-size: 32rpx; line-height: 1; } .action-bar { position: fixed; bottom: 0; left: 0; right: 0; background-color: white; padding: 20rpx; display: flex; gap: 20rpx; box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1); } .btn { flex: 1; height: 80rpx; border-radius: 8rpx; font-size: 28rpx; border: none; } .btn-primary { background-color: #4A90E2; color: white; } .btn-secondary { background-color: #ffffff; color: #4A90E2; border: 2rpx solid #4A90E2; }
